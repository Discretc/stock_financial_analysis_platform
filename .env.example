# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in all values marked <REQUIRED>
# Never commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development      # development | staging | production
APP_URL=http://localhost      # Public URL (used by Next.js rewrites and CORS)
SECRET_KEY=<REQUIRED>         # 64-char random hex: openssl rand -hex 32

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=finplatform
POSTGRES_PASSWORD=<REQUIRED>
POSTGRES_DB=finplatform

# Constructed by application code — do not set manually
# DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
# DATABASE_SYNC_URL=postgresql+psycopg2://...

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<REQUIRED>
REDIS_DB=0

# Cache TTLs (seconds) — optional, defaults shown
REDIS_TTL_QUOTES=15
REDIS_TTL_FINANCIALS=86400
REDIS_TTL_ANALYTICS=14400

# ── JWT / Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=<REQUIRED>              # 64-char random hex: openssl rand -hex 32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Financial Modeling Prep (FMP) API ─────────────────────────────────────────
FMP_API_KEY=<REQUIRED>                 # Your FMP API key
FMP_BASE_URL=https://financialmodelingprep.com/api/v3          # Used for search, quotes, profile
FMP_BASE_URL_STABLE=https://financialmodelingprep.com/stable   # Used for income/balance/cashflow statements
FMP_TIMEOUT_SECONDS=30

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2

# ── Flower (Celery monitoring) ────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=<REQUIRED>

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/yyy

# ── Email (optional — used for email verification) ────────────────────────────
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASSWORD=<SENDGRID_API_KEY>
# EMAIL_FROM=noreply@yourdomain.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info    # debug | info | warning | error
